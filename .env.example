# Example environment variables for local development
# Copy this file to .env.local and fill values (DO NOT commit .env.local)

# Supabase (client & anon key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (server only, DO NOT expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Gemini (Generative) API
# If not provided, the app will fall back to safe mocks for development.
GEMINI_API_KEY=your-gemini-api-key-or-bearer-token
GEMINI_MODEL=gemini-2.5-flash-lite
# Optional: custom API URL
# GEMINI_API_URL=

# Google Cloud Text-to-Speech
# Provide path to service account JSON for server-side TTS
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# Or configure application-default credentials instead of setting this variable
# Optionally provide project id
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# Node environment
NODE_ENV=development

# NOTE:
#  - Never commit .env.local or any file containing real secrets.
#  - Use .env.example as a reference only.
#  - After editing .env.local, restart the Next.js server to pick up changes.
